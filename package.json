{
  "name": "retrobuffer-bootstrap",
  "version": "1.1.0",
  "description": "RetroBuffer bootstrap for small self-contained canvas-based 2D JavaScript games",
  "main": "src/js/game.js",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "run-s clean build:js build:html",
    "build:size": "run-s build pack:roadroller package:zip report:size",
    "build:js": "rollup -c scripts/rollup.config.js --environment MINIFY",
    "build:html": "html-inline -b dist src/index.html | html-minifier -c scripts/htmlmin.json -o dist/index.html",
    "pack:roadroller": "node scripts/pack-roadroller.mjs",
    "package:zip": "node scripts/package-zip.mjs",
    "report:size": "node scripts/report-packed-sizes.mjs",
    "start": "npm-run-all -s clean -p dev:*",
    "dev:js": "rollup -c scripts/rollup.config.js -w --environment DEBUG --output.file dist/game.js",
    "dev:serve_watch_html_js": "browser-sync 'dist' 'src' --watch --host 0.0.0.0 --https --no-open",
    "dev:watch_img": "chokidar src/img -d 0 -c 'npm run dev:js'"
  },
  "license": "MIT",
  "devDependencies": {
    "@wwa/rollup-plugin-terser": "^1.1.2",
    "browser-sync": "^2.26.7",
    "chokidar-cli": "^2.0.0",
    "fflate": "^0.8.2",
    "html-inline": "^1.2.0",
    "html-minifier": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "roadroller": "^2.1.0",
    "rollup": "^2.23.0",
    "terser": "^5.40.0",
    "tinify": "^1.6.0-beta.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/herebefrogs/retrobuffer-bootstrap.git"
  },
  "author": "Jerome Lecomte <jerome@herebefrogs.com>",
  "bugs": {
    "url": "https://github.com/herebefrogs/retrobuffer-bootstrap/issues"
  },
  "homepage": "https://github.com/herebefrogs/retrobuffer-bootstrap#readme"
}
